<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="false">

    <!-- 状态栏占位 -->
    <View
        android:id="@+id/statusBarPlaceholder"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 左侧区域 - 榜单信息面板（无背景板） -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/leftPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintWidth_percent="0.38">

        <!-- 顶部渐变背景 -->
        <FrameLayout
            android:id="@+id/toolbarBackground"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/bg_chart_soaring"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/btnPlayAll">

            <!-- 装饰性圆形元素 -->
            <View
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="end|top"
                android:layout_marginEnd="-40dp"
                android:layout_marginTop="-40dp"
                android:background="@drawable/bg_circle_decorative"
                android:alpha="0.15" />

            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="start|bottom"
                android:layout_marginStart="-30dp"
                android:layout_marginBottom="40dp"
                android:background="@drawable/bg_circle_decorative"
                android:alpha="0.1" />

        </FrameLayout>

        <!-- 工具栏 -->
        <FrameLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:layout_constraintTop_toTopOf="parent">

            <!-- 返回按钮 -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back_modern"
                android:tint="@color/white"
                android:contentDescription="返回" />

        </FrameLayout>

        <!-- 榜单图标 -->
        <ImageView
            android:id="@+id/ivChartIcon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_trophy"
            android:tint="@color/white"
            android:alpha="0.9"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/toolbar" />

        <!-- 榜单标题 -->
        <TextView
            android:id="@+id/tvChartTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="24dp"
            android:text="飙升榜"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivChartIcon" />

        <!-- 榜单副标题 -->
        <TextView
            android:id="@+id/tvChartSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="24dp"
            android:text="热度飙升"
            android:textSize="16sp"
            android:textColor="#E6FFFFFF"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvChartTitle" />

        <!-- 歌曲数量 -->
        <TextView
            android:id="@+id/tvSongCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="100 首歌曲"
            android:textSize="14sp"
            android:textColor="#B3FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvChartSubtitle" />

        <!-- 播放全部按钮 - 蓝色背景 -->
        <LinearLayout
            android:id="@+id/btnPlayAll"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginBottom="32dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_play_all_button_blue"
            android:clickable="true"
            android:focusable="true"
            android:elevation="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_play_filled"
                android:tint="@color/white"
                android:contentDescription="播放" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="播放全部"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 分隔线 -->
    <View
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:background="@color/divider_light"
        app:layout_constraintStart_toEndOf="@id/leftPanel"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- 右侧区域 - 歌曲列表 -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintStart_toEndOf="@id/leftPanel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 歌曲列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChartSongs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:clipToPadding="false"
            tools:listitem="@layout/item_chart_song" />

        <!-- 加载进度条 -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:visibility="gone" />

        <!-- 空状态 -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_music_note"
                android:tint="@color/text_hint" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="暂无数据"
                android:textSize="16sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <!-- 批量操作栏容器 - 悬浮于列表右侧 -->
        <include
            android:id="@+id/batchActionBarContainerLand"
            layout="@layout/layout_batch_action_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="16dp"
            android:elevation="16dp"
            android:visibility="gone" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
