<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:fitsSystemWindows="false">

    <!-- 状态栏占位 -->
    <View
        android:id="@+id/statusBarPlaceholder"
        android:layout_width="match_parent"
        android:layout_height="0dp" />

    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back_modern"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/text_primary"
            android:contentDescription="返回" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="歌词设置"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

    </LinearLayout>

    <!-- 横屏三栏布局 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp">

            <!-- 左列：悬浮歌词 -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="悬浮歌词"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="设置悬浮歌词的颜色和大小"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:background="@drawable/bg_card_rounded"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvFloatingPreviewCurrent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="当前歌词预览"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="@color/primary" />

                        <TextView
                            android:id="@+id/tvFloatingPreviewNext"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="下一句歌词预览"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="大小"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <ImageButton
                            android:id="@+id/btnFloatingSizeDown"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_remove"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:tint="@color/text_primary"
                            android:contentDescription="减小悬浮歌词大小" />

                        <TextView
                            android:id="@+id/tvFloatingSizeValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="8dp"
                            android:text="20sp"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary" />

                        <ImageButton
                            android:id="@+id/btnFloatingSizeUp"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_add"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:tint="@color/text_primary"
                            android:contentDescription="增大悬浮歌词大小" />

                    </LinearLayout>

                    <GridLayout
                        android:id="@+id/gridFloatingColors"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:columnCount="6"
                        android:useDefaultMargins="true" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 中列：播放页歌词 -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="播放页歌词"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="设置播放页当前歌词的颜色和大小"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:background="@drawable/bg_card_rounded"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvPlayerPreviewCurrent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="播放页当前歌词"
                            android:textStyle="bold"
                            android:textSize="17sp"
                            android:textColor="@color/primary" />

                        <TextView
                            android:id="@+id/tvPlayerPreviewNext"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="播放页下一句歌词"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="大小"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <ImageButton
                            android:id="@+id/btnPlayerSizeDown"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_remove"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:tint="@color/text_primary"
                            android:contentDescription="减小播放页歌词大小" />

                        <TextView
                            android:id="@+id/tvPlayerSizeValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="8dp"
                            android:text="18sp"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary" />

                        <ImageButton
                            android:id="@+id/btnPlayerSizeUp"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_add"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:tint="@color/text_primary"
                            android:contentDescription="增大播放页歌词大小" />

                    </LinearLayout>

                    <GridLayout
                        android:id="@+id/gridPlayerColors"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:columnCount="6"
                        android:useDefaultMargins="true" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 右列：全屏歌词 -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="全屏歌词"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="设置全屏歌词当前行的颜色和大小"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:background="@drawable/bg_card_rounded"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvFullscreenPreviewCurrent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="全屏歌词当前行"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="@color/primary" />

                        <TextView
                            android:id="@+id/tvFullscreenPreviewNext"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="下一句歌词"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="大小"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <ImageButton
                            android:id="@+id/btnFullscreenSizeDown"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_remove"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:tint="@color/text_primary"
                            android:contentDescription="减小全屏歌词大小" />

                        <TextView
                            android:id="@+id/tvFullscreenSizeValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="8dp"
                            android:text="20sp"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary" />

                        <ImageButton
                            android:id="@+id/btnFullscreenSizeUp"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_add"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:tint="@color/text_primary"
                            android:contentDescription="增大全屏歌词大小" />

                    </LinearLayout>

                    <GridLayout
                        android:id="@+id/gridFullscreenColors"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:columnCount="6"
                        android:useDefaultMargins="true" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
