<?xml version="1.0" encoding="utf-8"?>
<!-- 横屏模式下的批量操作栏 - 双行网格布局，适配横屏左侧区域 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/batchActionBar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:elevation="8dp"
    android:visibility="gone"
    android:padding="6dp">

    <!-- 顶部：选中数量显示和关闭按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 选中数量显示 -->
        <TextView
            android:id="@+id/tvSelectedCount"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="0"
            android:textSize="12sp"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_nav_item_normal" />

        <!-- 垂直分割线 -->
        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="@color/divider_color"
            android:alpha="0.3"
            android:layout_marginHorizontal="6dp" />

        <!-- 关闭按钮 -->
        <ImageButton
            android:id="@+id/btnCloseBatch"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_secondary"
            android:contentDescription="关闭" />

    </LinearLayout>

    <!-- 水平分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_color"
        android:alpha="0.3"
        android:layout_marginVertical="6dp" />

    <!-- 操作按钮区域 - 使用双行网格布局 -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="2"
        android:alignmentMode="alignMargins"
        android:useDefaultMargins="false">

        <!-- 第一行 -->
        <!-- 全选 -->
        <LinearLayout
            android:id="@+id/btnSelectAll"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="3dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_select_all"
                android:tint="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="全选"
                android:textSize="9sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- 下载 -->
        <LinearLayout
            android:id="@+id/btnBatchDownload"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="3dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_download"
                android:tint="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="下载"
                android:textSize="9sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- 移除所选 -->
        <LinearLayout
            android:id="@+id/btnBatchRemove"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="3dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_remove"
                android:tint="@color/error" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="移除"
                android:textSize="9sp"
                android:textColor="@color/error" />
        </LinearLayout>

        <!-- 添加到喜欢 -->
        <LinearLayout
            android:id="@+id/btnAddToFavorite"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="3dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_heart"
                android:tint="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="喜欢"
                android:textSize="9sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- 第二行 -->
        <!-- 添加到歌单 -->
        <LinearLayout
            android:id="@+id/btnAddToPlaylist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="3dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_playlist_add"
                android:tint="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="歌单"
                android:textSize="9sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- 加入播放 -->
        <LinearLayout
            android:id="@+id/btnAddToNowPlaying"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="3dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_playlist_play"
                android:tint="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="播放"
                android:textSize="9sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- 清空列表 -->
        <LinearLayout
            android:id="@+id/btnClearAll"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="3dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_delete"
                android:tint="@color/error" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="清空"
                android:textSize="9sp"
                android:textColor="@color/error" />
        </LinearLayout>

    </GridLayout>

</LinearLayout>
