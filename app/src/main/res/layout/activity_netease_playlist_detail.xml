<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinatorLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="false">

    <!-- 状态栏占位 -->
    <View
        android:id="@+id/statusBarPlaceholder"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:elevation="10dp" />

    <!-- 沉浸式折叠工具栏 -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:fitsSystemWindows="false"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fitsSystemWindows="false"
            app:contentScrim="@color/background"
            app:expandedTitleGravity="bottom|start"
            app:expandedTitleMarginBottom="80dp"
            app:expandedTitleMarginStart="20dp"
            app:expandedTitleTextAppearance="@style/ExpandedTitleStyle"
            app:layout_scrollFlags="scroll|exitUntilCollapsed|snap"
            app:scrimAnimationDuration="300"
            app:statusBarScrim="@android:color/transparent"
            app:titleCollapseMode="scale">

            <!-- 沉浸式头部背景和内容 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fitsSystemWindows="false"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.5">

                <!-- 渐变背景层 - 动态颜色 -->
                <View
                    android:id="@+id/gradientBackground"
                    android:layout_width="match_parent"
                    android:layout_height="450dp"
                    android:background="@drawable/bg_playlist_header_gradient" />

                <!-- 模糊封面背景 -->
                <ImageView
                    android:id="@+id/ivBlurBackground"
                    android:layout_width="match_parent"
                    android:layout_height="450dp"
                    android:scaleType="centerCrop"
                    android:alpha="0.3" />

                <!-- 歌单信息头部内容 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="80dp"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- 歌单封面和信息 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- 封面卡片 - 带阴影和圆角 -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="150dp"
                            android:layout_height="150dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="16dp"
                            app:cardBackgroundColor="@color/surface">

                            <ImageView
                                android:id="@+id/ivPlaylistCover"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_album_default" />

                            <!-- 播放量遮罩 -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="top|end"
                                android:layout_margin="8dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="6dp"
                                android:paddingVertical="2dp"
                                android:background="@drawable/bg_play_count_badge">

                                <ImageView
                                    android:layout_width="10dp"
                                    android:layout_height="10dp"
                                    android:src="@drawable/ic_play_small"
                                    app:tint="@color/white" />

                                <TextView
                                    android:id="@+id/tvPlayCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="2dp"
                                    android:text="0"
                                    android:textSize="10sp"
                                    android:textColor="@color/white" />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                        <!-- 歌单信息 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">

                            <!-- 歌单名称 -->
                            <TextView
                                android:id="@+id/tvPlaylistName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="歌单名称"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/white"
                                android:maxLines="2"
                                android:ellipsize="end"
                                android:shadowColor="#40000000"
                                android:shadowDx="0"
                                android:shadowDy="2"
                                android:shadowRadius="4" />

                            <!-- 创建者信息 -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <androidx.cardview.widget.CardView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    app:cardCornerRadius="12dp"
                                    app:cardElevation="0dp">

                                    <ImageView
                                        android:id="@+id/ivCreatorAvatar"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:scaleType="centerCrop"
                                        android:src="@drawable/ic_album_default" />

                                </androidx.cardview.widget.CardView>

                                <TextView
                                    android:id="@+id/tvCreatorName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="创建者"
                                    android:textSize="13sp"
                                    android:textColor="#E0E0E0"
                                    android:shadowColor="#40000000"
                                    android:shadowDx="0"
                                    android:shadowDy="1"
                                    android:shadowRadius="2" />

                            </LinearLayout>

                            <!-- 歌曲数量 -->
                            <TextView
                                android:id="@+id/tvSongCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="0 首歌曲"
                                android:textSize="13sp"
                                android:textColor="#B0B0B0"
                                android:shadowColor="#40000000"
                                android:shadowDx="0"
                                android:shadowDy="1"
                                android:shadowRadius="2" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- 歌单描述 -->
                    <TextView
                        android:id="@+id/tvDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="暂无简介"
                        android:textSize="12sp"
                        android:textColor="#A0A0A0"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:lineSpacingMultiplier="1.2"
                        android:shadowColor="#40000000"
                        android:shadowDx="0"
                        android:shadowDy="1"
                        android:shadowRadius="2" />

                    <!-- 操作按钮区域 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal">

                        <!-- 播放全部按钮 -->
                        <LinearLayout
                            android:id="@+id/btnPlayAll"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_play_all_button_gradient"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:clickable="true"
                            android:focusable="true"
                            android:elevation="4dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_play_filled_modern"
                                app:tint="@color/white" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="播放全部"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/white" />

                        </LinearLayout>

                        <!-- 收藏按钮 -->
                        <LinearLayout
                            android:id="@+id/btnCollect"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/bg_action_button_circle"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:elevation="4dp">

                            <ImageView
                                android:id="@+id/ivCollect"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_heart_outline"
                                app:tint="@color/white" />

                        </LinearLayout>

                        <!-- 分享按钮 -->
                        <LinearLayout
                            android:id="@+id/btnShare"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/bg_action_button_circle"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:elevation="4dp">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_share"
                                app:tint="@color/white" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </FrameLayout>

            <!-- 工具栏 -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                app:contentInsetStartWithNavigation="0dp"
                app:layout_collapseMode="pin"
                app:navigationIcon="@drawable/ic_arrow_back_modern"
                app:title="歌单详情"
                app:titleTextColor="@color/text_primary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:text="歌单详情"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:maxLines="1"
                        android:ellipsize="end" />

                </LinearLayout>

            </androidx.appcompat.widget.Toolbar>

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- 内容区域 -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="100dp">

            <!-- 歌曲列表标题栏 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="歌曲列表"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvTrackCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 首"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

            <!-- 歌曲列表 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

            <!-- 加载更多进度条 -->
            <ProgressBar
                android:id="@+id/progressBarLoadMore"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:layout_marginVertical="20dp"
                android:visibility="gone"
                android:indeterminateTint="@color/primary" />

            <!-- 空状态 -->
            <LinearLayout
                android:id="@+id/emptyView"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    app:cardCornerRadius="45dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surface_light">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_music_note"
                        app:tint="@color/text_hint" />

                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="暂无歌曲"
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="该歌单暂时没有歌曲"
                    android:textSize="13sp"
                    android:textColor="@color/text_hint" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- 加载进度条 -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="@color/primary" />

    <!-- 批量操作栏 - 悬浮于列表右侧 -->
    <include
        android:id="@+id/batchActionBarContainer"
        layout="@layout/layout_batch_action_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="16dp"
        android:elevation="16dp"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
