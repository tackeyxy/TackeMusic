<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded_light"
    android:padding="16dp">

    <!-- 标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="选择音质"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary_light"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp" />

    <!-- 音质选项列表 -->
    <LinearLayout
        android:id="@+id/qualityContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HR 选项 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHR"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/surface_light_theme"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HR"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/vip_gold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hi-Res 无损音质"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary_light"
                        android:layout_marginTop="1dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FLAC 24bit"
                    android:textSize="10sp"
                    android:textColor="@color/text_tertiary_light"
                    android:background="@drawable/bg_quality_tag_light"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="3dp" />

                <ImageView
                    android:id="@+id/ivCheckHR"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_check"
                    android:tint="@color/primary"
                    android:layout_marginStart="10dp"
                    android:visibility="invisible" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- CDQ 选项 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCDQ"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/surface_light_theme"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CDQ"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_cyan" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CD 音质"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary_light"
                        android:layout_marginTop="1dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FLAC"
                    android:textSize="10sp"
                    android:textColor="@color/text_tertiary_light"
                    android:background="@drawable/bg_quality_tag_light"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="3dp" />

                <ImageView
                    android:id="@+id/ivCheckCDQ"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_check"
                    android:tint="@color/primary"
                    android:layout_marginStart="10dp"
                    android:visibility="invisible" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- HQ 选项 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHQ"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/surface_light_theme"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HQ"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="高品质"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary_light"
                        android:layout_marginTop="1dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="320K"
                    android:textSize="10sp"
                    android:textColor="@color/text_tertiary_light"
                    android:background="@drawable/bg_quality_tag_light"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="3dp" />

                <ImageView
                    android:id="@+id/ivCheckHQ"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_check"
                    android:tint="@color/primary"
                    android:layout_marginStart="10dp"
                    android:visibility="invisible" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- LQ 选项 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLQ"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_light_theme"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LQ"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary_light" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="标准音质"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary_light"
                        android:layout_marginTop="1dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="128K"
                    android:textSize="10sp"
                    android:textColor="@color/text_tertiary_light"
                    android:background="@drawable/bg_quality_tag_light"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="3dp" />

                <ImageView
                    android:id="@+id/ivCheckLQ"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_check"
                    android:tint="@color/primary"
                    android:layout_marginStart="10dp"
                    android:visibility="invisible" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- 确定按钮 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="确定"
        android:textColor="@color/white"
        android:textSize="15sp"
        app:backgroundTint="@color/primary"
        app:cornerRadius="10dp"
        android:layout_marginTop="16dp" />

</LinearLayout>
