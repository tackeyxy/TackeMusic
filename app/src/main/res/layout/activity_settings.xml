<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:fitsSystemWindows="false">

    <!-- 状态栏占位 -->
    <View
        android:id="@+id/statusBarPlaceholder"
        android:layout_width="match_parent"
        android:layout_height="0dp" />

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back_modern"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_primary"
            android:contentDescription="返回" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="设置"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

    </LinearLayout>

    <!-- 设置选项列表 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 默认音源设置 -->
        <LinearLayout
            android:id="@+id/layoutDefaultSource"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_rounded"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_quality"
                android:tint="@color/primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="默认音源"
                android:textSize="15sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvDefaultSourceValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="酷我"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_chevron_right"
                android:tint="@color/text_hint" />

        </LinearLayout>

        <!-- 歌词颜色设置 -->
        <LinearLayout
            android:id="@+id/layoutLyricColor"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_rounded"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_palette"
                android:tint="@color/primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="歌词设置"
                android:textSize="15sp"
                android:textColor="@color/text_primary" />

            <View
                android:id="@+id/viewLyricColorPreview"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_color_circle" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_chevron_right"
                android:tint="@color/text_hint" />

        </LinearLayout>

        <!-- 同时下载个数设置 -->
        <LinearLayout
            android:id="@+id/layoutConcurrentDownloads"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_rounded"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_download"
                android:tint="@color/primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="同时下载个数"
                android:textSize="15sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvConcurrentDownloadsValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_chevron_right"
                android:tint="@color/text_hint" />

        </LinearLayout>

        <!-- 默认下载音质设置 -->
        <LinearLayout
            android:id="@+id/layoutDefaultDownloadQuality"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_rounded"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_quality"
                android:tint="@color/primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="默认下载音质"
                android:textSize="15sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvDefaultDownloadQualityValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HQ (320K)"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_chevron_right"
                android:tint="@color/text_hint" />

        </LinearLayout>

        <!-- 缓存过期时间设置 -->
        <LinearLayout
            android:id="@+id/layoutCacheExpiry"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_rounded"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_timer"
                android:tint="@color/primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="缓存过期时间"
                android:textSize="15sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvCacheExpiryValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7 天"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_chevron_right"
                android:tint="@color/text_hint" />

        </LinearLayout>

        <!-- 下载位置设置 -->
        <LinearLayout
            android:id="@+id/layoutDownloadPath"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_rounded"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_download_white"
                android:tint="@color/primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="下载位置"
                android:textSize="15sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvDownloadPathValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="150dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="默认位置"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_chevron_right"
                android:tint="@color/text_hint" />

        </LinearLayout>

        <!-- 日志管理 -->
        <LinearLayout
            android:id="@+id/layoutLogViewer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_rounded"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_log"
                android:tint="@color/primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="日志管理"
                android:textSize="15sp"
                android:textColor="@color/text_primary" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_chevron_right"
                android:tint="@color/text_hint" />

        </LinearLayout>

        <!-- 检查更新 -->
        <LinearLayout
            android:id="@+id/layoutCheckUpdate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_rounded"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_update"
                android:tint="@color/primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="检查更新"
                android:textSize="15sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvCurrentVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0.1"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_chevron_right"
                android:tint="@color/text_hint" />

        </LinearLayout>

        <!-- 关于 -->
        <LinearLayout
            android:id="@+id/layoutAbout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_rounded"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_discover"
                android:tint="@color/primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="关于"
                android:textSize="15sp"
                android:textColor="@color/text_primary" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_chevron_right"
                android:tint="@color/text_hint" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
