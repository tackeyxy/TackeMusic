<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back_modern"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/text_primary"
            android:contentDescription="返回" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="歌词设置"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

    </LinearLayout>

    <!-- 设置选项列表 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 播放页歌词颜色设置 -->
        <LinearLayout
            android:id="@+id/layoutPlayerLyricColor"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_rounded"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_palette"
                app:tint="@color/primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="播放页歌词颜色"
                android:textSize="15sp"
                android:textColor="@color/text_primary" />

            <View
                android:id="@+id/viewPlayerLyricColorPreview"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_color_circle" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/text_hint" />

        </LinearLayout>

        <!-- 悬浮歌词开关 -->
        <LinearLayout
            android:id="@+id/layoutFloatingLyricsSwitch"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_rounded"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_floating_lyrics"
                app:tint="@color/primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="启用悬浮歌词"
                android:textSize="15sp"
                android:textColor="@color/text_primary" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchFloatingLyrics"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- 悬浮歌词颜色设置 -->
        <LinearLayout
            android:id="@+id/layoutFloatingLyricColor"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_rounded"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_palette"
                app:tint="@color/primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="悬浮歌词颜色"
                android:textSize="15sp"
                android:textColor="@color/text_primary" />

            <View
                android:id="@+id/viewFloatingLyricColorPreview"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_color_circle" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/text_hint" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
