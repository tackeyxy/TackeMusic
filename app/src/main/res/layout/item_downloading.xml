<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- 删除按钮背景层 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/deleteLayout"
        android:layout_width="80dp"
        android:layout_height="0dp"
        android:background="@color/accent_purple"
        app:layout_constraintTop_toTopOf="@id/contentLayout"
        app:layout_constraintBottom_toBottomOf="@id/contentLayout"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_delete"
            android:tint="@color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 内容层 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 多选复选框 -->
        <FrameLayout
            android:id="@+id/flCheckbox"
            android:layout_width="32dp"
            android:layout_height="56dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/ivCheckbox"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/selector_checkbox_circle"
                android:contentDescription="选择" />

        </FrameLayout>

        <!-- 封面 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvCover"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="4dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toEndOf="@id/flCheckbox"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivCover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_album_default" />

        </androidx.cardview.widget.CardView>

        <!-- 歌曲信息 -->
        <TextView
            android:id="@+id/tvSongName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:text="歌曲名称"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/cvCover"
            app:layout_constraintEnd_toStartOf="@id/btnControl"
            app:layout_constraintTop_toTopOf="@id/cvCover" />

        <TextView
            android:id="@+id/tvArtist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:text="歌手名称"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/cvCover"
            app:layout_constraintEnd_toStartOf="@id/btnControl"
            app:layout_constraintTop_toBottomOf="@id/tvSongName" />

        <!-- 进度条 -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:progressDrawable="@drawable/bg_download_progress"
            android:max="100"
            app:layout_constraintStart_toEndOf="@id/cvCover"
            app:layout_constraintEnd_toStartOf="@id/tvProgress"
            app:layout_constraintTop_toBottomOf="@id/tvArtist" />

        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            app:layout_constraintEnd_toStartOf="@id/btnControl"
            app:layout_constraintTop_toTopOf="@id/progressBar"
            app:layout_constraintBottom_toBottomOf="@id/progressBar" />

        <!-- 控制按钮 -->
        <ImageButton
            android:id="@+id/btnControl"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_pause"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/primary"
            android:padding="6dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- 下载速度和大小信息 -->
        <TextView
            android:id="@+id/tvSpeed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:text="0KB/s"
            android:textSize="11sp"
            android:textColor="@color/primary"
            app:layout_constraintStart_toEndOf="@id/cvCover"
            app:layout_constraintTop_toBottomOf="@id/progressBar" />

        <TextView
            android:id="@+id/tvSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="0MB / 0MB"
            android:textSize="11sp"
            android:textColor="@color/text_tertiary"
            app:layout_constraintStart_toEndOf="@id/tvSpeed"
            app:layout_constraintTop_toTopOf="@id/tvSpeed" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
