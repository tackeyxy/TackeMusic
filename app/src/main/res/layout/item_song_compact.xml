<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="2dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/surface">

    <FrameLayout
        android:id="@+id/itemContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 圆形复选框 - 多选模式显示 -->
            <FrameLayout
                android:id="@+id/flCheckbox"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/ivCheckbox"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/selector_checkbox_circle"
                    android:contentDescription="选择" />

            </FrameLayout>

            <!-- 序号 - 非多选模式显示 -->
            <TextView
                android:id="@+id/tvIndex"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:visibility="visible"
                tools:text="1" />

            <!-- 歌曲封面容器 -->
            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cvCover"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="6dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/ivCover"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_music_note" />

                </androidx.cardview.widget.CardView>

                <!-- 选中时的封面遮罩 -->
                <View
                    android:id="@+id/coverOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_item_selected"
                    android:alpha="0"
                    android:visibility="gone" />

            </FrameLayout>

            <!-- 歌曲信息 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="6dp"
                android:orientation="vertical">

                <!-- 歌名 -->
                <TextView
                    android:id="@+id/tvSongName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="歌曲名称" />

                <!-- 歌手和额外信息 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- 音源图标 -->
                    <ImageView
                        android:id="@+id/ivSource"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="3dp"
                        android:scaleType="fitCenter"
                        tools:src="@drawable/ic_netease_logo" />

                    <!-- 歌手 -->
                    <TextView
                        android:id="@+id/tvArtist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:maxLines="1"
                        android:ellipsize="end"
                        tools:text="艺术家" />

                    <!-- 分隔点 -->
                    <TextView
                        android:id="@+id/tvDot"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="3dp"
                        android:text="·"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint" />

                    <!-- 额外信息（如时长、大小等） -->
                    <TextView
                        android:id="@+id/tvExtra"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/text_tertiary"
                        android:maxLines="1"
                        tools:text="3:45" />

                </LinearLayout>

                <!-- 进度信息（下载页面使用） -->
                <LinearLayout
                    android:id="@+id/layoutProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone">

                    <ProgressBar
                        android:id="@+id/progressBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="50dp"
                        android:layout_height="2dp"
                        android:progressDrawable="@drawable/bg_download_progress"
                        android:max="100" />

                    <TextView
                        android:id="@+id/tvProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="0%"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvSpeed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="0KB/s"
                        android:textSize="10sp"
                        android:textColor="@color/primary" />

                </LinearLayout>

            </LinearLayout>

            <!-- 状态文字 -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="@color/text_tertiary"
                android:visibility="gone"
                tools:text="12-01 14:30" />

        </LinearLayout>

    </FrameLayout>

</androidx.cardview.widget.CardView>
