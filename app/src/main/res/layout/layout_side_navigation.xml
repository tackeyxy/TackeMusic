<?xml version="1.0" encoding="utf-8"?>
<!-- 可复用的左侧导航栏组件 - 3个图标均匀分布版 -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/sideNav"
    android:layout_width="68dp"
    android:layout_height="match_parent"
    android:layout_margin="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/nav_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="32dp"
        android:paddingBottom="20dp">

        <!-- 顶部占位 - 将3个导航项推向中间 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 推荐导航项 -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="52dp"
            android:layout_height="60dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_nav_item_normal"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/ivNavHome"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_home"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/tvNavHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="首页"
                android:textSize="10sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <!-- 播放器导航项 -->
        <LinearLayout
            android:id="@+id/navDiscover"
            android:layout_width="52dp"
            android:layout_height="60dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_nav_item_normal"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/ivNavDiscover"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_discover"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/tvNavDiscover"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="播放"
                android:textSize="10sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <!-- 我的导航项 -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="52dp"
            android:layout_height="60dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_nav_item_normal"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/ivNavProfile"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_profile"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/tvNavProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="我的"
                android:textSize="10sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <!-- 中间占位 - 将设置按钮推到底部 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2" />

        <!-- 设置按钮 -->
        <FrameLayout
            android:id="@+id/navSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_settings"
                app:tint="@color/text_tertiary" />

        </FrameLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
