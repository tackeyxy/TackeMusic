<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- 顶部渐变背景区域 -->
    <FrameLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:background="@drawable/bg_update_header_gradient">

        <!-- 返回按钮 -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="start|top"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back_modern"
            app:tint="@color/white"
            android:contentDescription="返回" />

        <!-- 顶部内容区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <!-- 新版本标签 -->
            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="新版本"
                android:textSize="12sp"
                android:textStyle="bold"
                app:chipBackgroundColor="@color/white"
                app:chipStrokeWidth="0dp"
                android:textColor="@color/primary"
                app:chipMinHeight="28dp"
                app:chipStartPadding="16dp"
                app:chipEndPadding="16dp" />

            <!-- 应用图标 -->
            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="20dp"
                android:src="@mipmap/ic_launcher"
                android:background="@drawable/bg_update_app_icon_round"
                android:elevation="8dp" />

            <!-- 版本号 -->
            <TextView
                android:id="@+id/tvNewVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="v1.0.1"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <!-- 版本信息标签 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFileSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10.5 MB"
                    android:textSize="13sp"
                    app:chipBackgroundColor="#40FFFFFF"
                    app:chipStrokeWidth="0dp"
                    android:textColor="@color/white"
                    app:chipMinHeight="32dp"
                    app:chipStartPadding="12dp"
                    app:chipEndPadding="12dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPublishTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="2024-01-01"
                    android:textSize="13sp"
                    app:chipBackgroundColor="#40FFFFFF"
                    app:chipStrokeWidth="0dp"
                    android:textColor="@color/white"
                    app:chipMinHeight="32dp"
                    app:chipStartPadding="12dp"
                    app:chipEndPadding="12dp" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- 内容区域 - 可滚动 -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="280dp"
        android:background="@drawable/bg_card_rounded"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- 当前版本对比 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_rounded"
                android:padding="16dp">

                <!-- 左侧：当前版本 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="当前版本"
                        android:textSize="12sp"
                        android:textColor="@color/text_tertiary" />

                    <TextView
                        android:id="@+id/tvCurrentVersion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="v1.0.0"
                        android:textSize="18sp"
                        android:textColor="@color/text_secondary" />

                </LinearLayout>

                <!-- 中间箭头 -->
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginHorizontal="12dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/primary" />

                <!-- 右侧：新版本 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="新版本"
                        android:textSize="12sp"
                        android:textColor="@color/text_tertiary" />

                    <TextView
                        android:id="@+id/tvCurrentVersionNew"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="v1.0.1"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary" />

                </LinearLayout>

            </LinearLayout>

            <!-- 更新内容标题 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="4dp"
                    android:layout_height="24dp"
                    android:background="@color/primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="更新内容"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:background="@color/divider_light" />

            </LinearLayout>

            <!-- 更新日志内容 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/surface">

                <TextView
                    android:id="@+id/tvReleaseNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:text="1. 修复了一些bug\n2. 优化了性能\n3. 新增了一些功能"
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.6" />

            </com.google.android.material.card.MaterialCardView>

            <!-- 下载进度 -->
            <LinearLayout
                android:id="@+id/layoutProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ProgressBar
                        android:id="@+id/progressBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="1"
                        android:progressDrawable="@drawable/progress_horizontal"
                        android:max="100" />

                    <TextView
                        android:id="@+id/tvProgressText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="0%"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:minWidth="50dp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvProgressDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="正在下载更新包..."
                    android:textSize="13sp"
                    android:textColor="@color/text_tertiary" />

            </LinearLayout>

            <!-- 操作按钮区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal">

                <!-- 忽略更新按钮 - 描边样式 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnIgnoreUpdate"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="忽略此版本"
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary"
                    android:textAllCaps="false"
                    android:minHeight="52dp"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="26dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/divider"
                    app:backgroundTint="@color/white"
                    app:rippleColor="@color/divider_light"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <!-- 下载更新按钮 - 填充渐变样式 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDownloadUpdate"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="立即下载"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:textAllCaps="false"
                    android:minHeight="52dp"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="26dp"
                    app:backgroundTint="@null"
                    android:background="@drawable/bg_button_primary_gradient"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
