<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootContainer"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="4dp">

    <!-- 歌词容器 -->
    <LinearLayout
        android:id="@+id/lyricsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:background="@drawable/bg_floating_lyrics">

        <!-- 当前歌词行 - 使用HorizontalScrollView实现滚动 -->
        <HorizontalScrollView
            android:id="@+id/scrollCurrentLine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:overScrollMode="never">

            <TextView
                android:id="@+id/tvCurrentLine"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="歌词加载中..."
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:gravity="center"
                android:singleLine="true"
                android:ellipsize="none"
                android:paddingHorizontal="8dp"
                android:shadowColor="#80000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2" />
        </HorizontalScrollView>

        <!-- 下一句歌词 - 使用HorizontalScrollView实现滚动 -->
        <HorizontalScrollView
            android:id="@+id/scrollNextLine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:scrollbars="none"
            android:overScrollMode="never">

            <TextView
                android:id="@+id/tvNextLine"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#80FFFFFF"
                android:gravity="center"
                android:singleLine="true"
                android:ellipsize="none"
                android:paddingHorizontal="8dp"
                android:shadowColor="#80000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2" />
        </HorizontalScrollView>

        <!-- 快速调整控件容器 -->
        <LinearLayout
            android:id="@+id/quickSettingsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:visibility="gone">

            <!-- 字体大小调整行 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- 减小按钮 -->
                <ImageView
                    android:id="@+id/btnDecreaseSize"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_remove"
                    android:background="@drawable/bg_control_button"
                    app:tint="#CCFFFFFF"
                    android:contentDescription="减小字体" />

                <!-- 大小显示 -->
                <TextView
                    android:id="@+id/tvSizeValue"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="100%"
                    android:textSize="12sp"
                    android:textColor="#CCFFFFFF" />

                <!-- 增加按钮 -->
                <ImageView
                    android:id="@+id/btnIncreaseSize"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_add"
                    android:background="@drawable/bg_control_button"
                    app:tint="#CCFFFFFF"
                    android:contentDescription="增大字体" />

            </LinearLayout>

            <!-- 字体大小滑动条 -->
            <SeekBar
                android:id="@+id/seekBarSize"
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:max="150"
                android:progress="50"
                android:progressDrawable="@drawable/seekbar_progress"
                android:thumb="@drawable/seekbar_thumb" />

            <!-- 颜色选择网格 -->
            <GridLayout
                android:id="@+id/colorPickerContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:columnCount="6"
                android:orientation="horizontal"
                android:alignmentMode="alignMargins">
                <!-- 颜色按钮将动态添加 -->
            </GridLayout>

            <!-- 恢复默认按钮 -->
            <TextView
                android:id="@+id/btnResetDefault"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="恢复默认"
                android:textSize="11sp"
                android:textColor="#CCFFFFFF"
                android:background="@drawable/bg_control_button"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- 播放控制按钮容器 -->
        <LinearLayout
            android:id="@+id/playbackControlContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:visibility="gone">

            <!-- 上一首按钮 -->
            <ImageView
                android:id="@+id/btnPrevious"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="6dp"
                android:src="@drawable/ic_skip_previous"
                android:background="@drawable/bg_control_button"
                app:tint="#CCFFFFFF"
                android:contentDescription="上一首" />

            <!-- 播放/暂停按钮 -->
            <ImageView
                android:id="@+id/btnPlayPause"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="12dp"
                android:padding="6dp"
                android:src="@drawable/ic_play"
                android:background="@drawable/bg_control_button"
                app:tint="#CCFFFFFF"
                android:contentDescription="播放/暂停" />

            <!-- 下一首按钮 -->
            <ImageView
                android:id="@+id/btnNext"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="6dp"
                android:src="@drawable/ic_skip_next"
                android:background="@drawable/bg_control_button"
                app:tint="#CCFFFFFF"
                android:contentDescription="下一首" />

        </LinearLayout>

        <!-- 控制按钮容器 -->
        <LinearLayout
            android:id="@+id/controlContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:visibility="gone">

            <!-- 设置按钮 -->
            <ImageView
                android:id="@+id/btnSettings"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="6dp"
                android:src="@drawable/ic_settings"
                android:background="@drawable/bg_control_button"
                app:tint="#CCFFFFFF"
                android:contentDescription="快速设置" />

            <!-- 锁定/解锁按钮 -->
            <ImageView
                android:id="@+id/btnLock"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="12dp"
                android:padding="6dp"
                android:src="@drawable/ic_lock_open"
                android:background="@drawable/bg_control_button"
                app:tint="#CCFFFFFF"
                android:contentDescription="锁定/解锁" />

            <!-- 关闭按钮 -->
            <ImageView
                android:id="@+id/btnClose"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="12dp"
                android:padding="6dp"
                android:src="@drawable/ic_close"
                android:background="@drawable/bg_control_button"
                app:tint="#CCFFFFFF"
                android:contentDescription="关闭" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
