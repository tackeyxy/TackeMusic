<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/surface">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:background="?attr/selectableItemBackground">

        <!-- 左侧：歌曲封面 + 信息 整体靠左 -->
        <LinearLayout
            android:id="@+id/llLeftContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@id/llRightArea"
            android:layout_marginEnd="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 复选框/播放指示器 - 默认隐藏，多选时显示 -->
            <FrameLayout
                android:id="@+id/flIndex"
                android:layout_width="32dp"
                android:layout_height="56dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/ivCheckbox"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/selector_checkbox_circle"
                    android:contentDescription="选择" />

            </FrameLayout>

            <!-- 歌曲封面 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvCover"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="0dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/ivCover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_music_note" />
            </androidx.cardview.widget.CardView>

            <!-- 歌曲信息（歌名+歌手+进度） -->
            <LinearLayout
                android:id="@+id/llSongInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <!-- 歌名 -->
                <TextView
                    android:id="@+id/tvSongName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="歌曲名称" />

                <!-- 歌手 -->
                <TextView
                    android:id="@+id/tvArtist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="艺术家" />

                <!-- 来源和音质标签 -->
                <LinearLayout
                    android:id="@+id/layoutSourceQuality"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- 音源图标 -->
                    <ImageView
                        android:id="@+id/ivSource"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:scaleType="fitCenter"
                        tools:src="@drawable/ic_kuwo_logo" />

                    <!-- 音质标签 -->
                    <TextView
                        android:id="@+id/tvQuality"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:textSize="10sp"
                        android:textColor="@color/primary"
                        android:background="@drawable/bg_quality_tag_light"
                        android:paddingHorizontal="4dp"
                        android:paddingVertical="1dp"
                        tools:text="320K" />

                </LinearLayout>

                <!-- 进度信息（仅正在下载显示） -->
                <LinearLayout
                    android:id="@+id/layoutProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ProgressBar
                        android:id="@+id/progressBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="80dp"
                        android:layout_height="3dp"
                        android:progressDrawable="@drawable/bg_download_progress"
                        android:max="100" />

                    <TextView
                        android:id="@+id/tvProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="0%"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvSpeed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="0KB/s"
                        android:textSize="11sp"
                        android:textColor="@color/primary" />

                </LinearLayout>

                <!-- 大小信息（仅历史记录显示） -->
                <TextView
                    android:id="@+id/tvSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="0MB"
                    android:textSize="11sp"
                    android:textColor="@color/text_tertiary"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

        <!-- 右侧：状态/操作按钮 - 靠最右侧 -->
        <LinearLayout
            android:id="@+id/llRightArea"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 状态文字（历史记录） -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/text_tertiary"
                android:visibility="gone"
                tools:text="12-01 14:30" />

            <!-- 控制按钮（正在下载） -->
            <ImageButton
                android:id="@+id/btnControl"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_pause"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/primary"
                android:padding="6dp"
                android:contentDescription="控制" />

        </LinearLayout>

    </RelativeLayout>

</androidx.cardview.widget.CardView>
