<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.MainActivity">

    <!-- 搜索栏 -->
    <LinearLayout
        android:id="@+id/searchLayout"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_search_bar"
        android:paddingStart="4dp"
        android:paddingEnd="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 音乐源选择器 -->
        <LinearLayout
            android:id="@+id/layoutSourceSelector"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_source_selector"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/tvSourceSelector"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="酷我"
                android:textSize="13sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:gravity="center" />

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_dropdown"
                android:tint="@color/white" />

        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="16dp"
            android:layout_marginHorizontal="8dp"
            android:background="@color/divider" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_search"
            android:tint="@color/text_hint" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@null"
            android:hint="搜索歌曲、艺人、专辑"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:maxLines="1"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:gravity="center_vertical" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_mic"
            android:tint="@color/text_hint" />

    </LinearLayout>

    <!-- 内容区域 - 重新设计为4个榜单 -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="80dp"
        app:layout_constraintTop_toBottomOf="@id/searchLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- 榜单标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="音乐榜单"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="发现热门音乐，掌握流行趋势"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />

            <!-- 4个榜单卡片 - 2x2网格布局 -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:columnCount="2"
                android:rowCount="2"
                android:useDefaultMargins="false">

                <!-- 飙升榜 -->
                <FrameLayout
                    android:id="@+id/cardSoaring"
                    android:layout_width="0dp"
                    android:layout_height="200dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_chart_soaring"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="飙升榜"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="热度飙升"
                            android:textSize="11sp"
                            android:textColor="#80FFFFFF" />

                        <!-- 前三首歌曲 - 可点击 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="8dp">

                            <LinearLayout
                                android:id="@+id/songSoaring1"
                                android:layout_width="match_parent"
                                android:layout_height="36dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingHorizontal="4dp">

                                <TextView
                                    android:layout_width="16dp"
                                    android:layout_height="wrap_content"
                                    android:text="1"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#FFD700" />

                                <TextView
                                    android:id="@+id/tvSoaringSong1"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="6dp"
                                    android:text="加载中..."
                                    android:textSize="12sp"
                                    android:textColor="@color/white"
                                    android:maxLines="1"
                                    android:ellipsize="end" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_play"
                                    android:tint="#80FFFFFF" />

                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/songSoaring2"
                                android:layout_width="match_parent"
                                android:layout_height="36dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingHorizontal="4dp">

                                <TextView
                                    android:layout_width="16dp"
                                    android:layout_height="wrap_content"
                                    android:text="2"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#C0C0C0" />

                                <TextView
                                    android:id="@+id/tvSoaringSong2"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="6dp"
                                    android:text="加载中..."
                                    android:textSize="12sp"
                                    android:textColor="#E6FFFFFF"
                                    android:maxLines="1"
                                    android:ellipsize="end" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_play"
                                    android:tint="#80FFFFFF" />

                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/songSoaring3"
                                android:layout_width="match_parent"
                                android:layout_height="36dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingHorizontal="4dp">

                                <TextView
                                    android:layout_width="16dp"
                                    android:layout_height="wrap_content"
                                    android:text="3"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#CD7F32" />

                                <TextView
                                    android:id="@+id/tvSoaringSong3"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="6dp"
                                    android:text="加载中..."
                                    android:textSize="12sp"
                                    android:textColor="#CCFFFFFF"
                                    android:maxLines="1"
                                    android:ellipsize="end" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_play"
                                    android:tint="#80FFFFFF" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </FrameLayout>

                <!-- 新歌榜 -->
                <FrameLayout
                    android:id="@+id/cardNew"
                    android:layout_width="0dp"
                    android:layout_height="200dp"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_chart_new"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="新歌榜"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="最新发布"
                            android:textSize="11sp"
                            android:textColor="#80FFFFFF" />

                        <!-- 前三首歌曲 - 可点击 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="8dp">

                            <LinearLayout
                                android:id="@+id/songNew1"
                                android:layout_width="match_parent"
                                android:layout_height="36dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingHorizontal="4dp">

                                <TextView
                                    android:layout_width="16dp"
                                    android:layout_height="wrap_content"
                                    android:text="1"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#FFD700" />

                                <TextView
                                    android:id="@+id/tvNewSong1"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="6dp"
                                    android:text="加载中..."
                                    android:textSize="12sp"
                                    android:textColor="@color/white"
                                    android:maxLines="1"
                                    android:ellipsize="end" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_play"
                                    android:tint="#80FFFFFF" />

                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/songNew2"
                                android:layout_width="match_parent"
                                android:layout_height="36dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingHorizontal="4dp">

                                <TextView
                                    android:layout_width="16dp"
                                    android:layout_height="wrap_content"
                                    android:text="2"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#C0C0C0" />

                                <TextView
                                    android:id="@+id/tvNewSong2"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="6dp"
                                    android:text="加载中..."
                                    android:textSize="12sp"
                                    android:textColor="#E6FFFFFF"
                                    android:maxLines="1"
                                    android:ellipsize="end" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_play"
                                    android:tint="#80FFFFFF" />

                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/songNew3"
                                android:layout_width="match_parent"
                                android:layout_height="36dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingHorizontal="4dp">

                                <TextView
                                    android:layout_width="16dp"
                                    android:layout_height="wrap_content"
                                    android:text="3"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#CD7F32" />

                                <TextView
                                    android:id="@+id/tvNewSong3"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="6dp"
                                    android:text="加载中..."
                                    android:textSize="12sp"
                                    android:textColor="#CCFFFFFF"
                                    android:maxLines="1"
                                    android:ellipsize="end" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_play"
                                    android:tint="#80FFFFFF" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </FrameLayout>

                <!-- 原创榜 -->
                <FrameLayout
                    android:id="@+id/cardOriginal"
                    android:layout_width="0dp"
                    android:layout_height="200dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chart_original"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="原创榜"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="原创作品"
                            android:textSize="11sp"
                            android:textColor="#80FFFFFF" />

                        <!-- 前三首歌曲 - 可点击 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="8dp">

                            <LinearLayout
                                android:id="@+id/songOriginal1"
                                android:layout_width="match_parent"
                                android:layout_height="36dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingHorizontal="4dp">

                                <TextView
                                    android:layout_width="16dp"
                                    android:layout_height="wrap_content"
                                    android:text="1"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#FFD700" />

                                <TextView
                                    android:id="@+id/tvOriginalSong1"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="6dp"
                                    android:text="加载中..."
                                    android:textSize="12sp"
                                    android:textColor="@color/white"
                                    android:maxLines="1"
                                    android:ellipsize="end" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_play"
                                    android:tint="#80FFFFFF" />

                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/songOriginal2"
                                android:layout_width="match_parent"
                                android:layout_height="36dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingHorizontal="4dp">

                                <TextView
                                    android:layout_width="16dp"
                                    android:layout_height="wrap_content"
                                    android:text="2"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#C0C0C0" />

                                <TextView
                                    android:id="@+id/tvOriginalSong2"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="6dp"
                                    android:text="加载中..."
                                    android:textSize="12sp"
                                    android:textColor="#E6FFFFFF"
                                    android:maxLines="1"
                                    android:ellipsize="end" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_play"
                                    android:tint="#80FFFFFF" />

                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/songOriginal3"
                                android:layout_width="match_parent"
                                android:layout_height="36dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingHorizontal="4dp">

                                <TextView
                                    android:layout_width="16dp"
                                    android:layout_height="wrap_content"
                                    android:text="3"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#CD7F32" />

                                <TextView
                                    android:id="@+id/tvOriginalSong3"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="6dp"
                                    android:text="加载中..."
                                    android:textSize="12sp"
                                    android:textColor="#CCFFFFFF"
                                    android:maxLines="1"
                                    android:ellipsize="end" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_play"
                                    android:tint="#80FFFFFF" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </FrameLayout>

                <!-- 热歌榜 -->
                <FrameLayout
                    android:id="@+id/cardHot"
                    android:layout_width="0dp"
                    android:layout_height="200dp"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chart_hot"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="热歌榜"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="全网热门"
                            android:textSize="11sp"
                            android:textColor="#80FFFFFF" />

                        <!-- 前三首歌曲 - 可点击 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="8dp">

                            <LinearLayout
                                android:id="@+id/songHot1"
                                android:layout_width="match_parent"
                                android:layout_height="36dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingHorizontal="4dp">

                                <TextView
                                    android:layout_width="16dp"
                                    android:layout_height="wrap_content"
                                    android:text="1"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#FFD700" />

                                <TextView
                                    android:id="@+id/tvHotSong1"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="6dp"
                                    android:text="加载中..."
                                    android:textSize="12sp"
                                    android:textColor="@color/white"
                                    android:maxLines="1"
                                    android:ellipsize="end" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_play"
                                    android:tint="#80FFFFFF" />

                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/songHot2"
                                android:layout_width="match_parent"
                                android:layout_height="36dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingHorizontal="4dp">

                                <TextView
                                    android:layout_width="16dp"
                                    android:layout_height="wrap_content"
                                    android:text="2"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#C0C0C0" />

                                <TextView
                                    android:id="@+id/tvHotSong2"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="6dp"
                                    android:text="加载中..."
                                    android:textSize="12sp"
                                    android:textColor="#E6FFFFFF"
                                    android:maxLines="1"
                                    android:ellipsize="end" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_play"
                                    android:tint="#80FFFFFF" />

                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/songHot3"
                                android:layout_width="match_parent"
                                android:layout_height="36dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingHorizontal="4dp">

                                <TextView
                                    android:layout_width="16dp"
                                    android:layout_height="wrap_content"
                                    android:text="3"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#CD7F32" />

                                <TextView
                                    android:id="@+id/tvHotSong3"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="6dp"
                                    android:text="加载中..."
                                    android:textSize="12sp"
                                    android:textColor="#CCFFFFFF"
                                    android:maxLines="1"
                                    android:ellipsize="end" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_play"
                                    android:tint="#80FFFFFF" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </FrameLayout>

            </GridLayout>

            <!-- 推荐歌单区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="推荐歌单"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <!-- 风格标签横向滚动 -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPlaylistTags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:clipToPadding="false"
                    android:paddingEnd="16dp" />

                <!-- 歌单网格 -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecommendPlaylists"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:nestedScrollingEnabled="false" />

                <!-- 加载更多进度条 -->
                <ProgressBar
                    android:id="@+id/progressBarPlaylistLoadMore"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- 底部留白 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="24dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- 搜索结果列表 - 放在 NestedScrollView 外部 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSongs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="160dp"
        android:clipToPadding="false"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/searchLayout"
        app:layout_constraintBottom_toTopOf="@id/bottomNav" />

    <!-- 底部导航栏 - 保留不动 -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:background="@color/surface"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/ivNavHome"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/selector_nav_home" />

            <TextView
                android:id="@+id/tvNavHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="推荐"
                android:textSize="12sp"
                android:textColor="@color/primary" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/navDiscover"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/ivNavDiscover"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/selector_nav_discover" />

            <TextView
                android:id="@+id/tvNavDiscover"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="播放器"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/ivNavProfile"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/selector_nav_profile" />

            <TextView
                android:id="@+id/tvNavProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="我的"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

    </LinearLayout>

    <!-- 加载进度条 -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 批量操作栏 - 位于底部导航栏上方 -->
    <include
        android:id="@+id/batchActionBarContainer"
        layout="@layout/layout_batch_action_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav" />

    <!-- 底部加载更多进度条 -->
    <ProgressBar
        android:id="@+id/progressBarLoadMore"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:visibility="gone"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/batchActionBarContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
