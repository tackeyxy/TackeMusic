<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="12dp">

    <!-- 音质选项列表 - 水平排列 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- HR 选项 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHR"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="@color/surface_light"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HR"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/vip_gold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24bit"
                    android:textSize="9sp"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginTop="2dp" />

                <ImageView
                    android:id="@+id/ivCheckHR"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_check"
                    android:tint="@color/primary"
                    android:layout_marginTop="2dp"
                    android:visibility="gone" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- CDQ 选项 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCDQ"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="@color/surface_light"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CDQ"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_cyan" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FLAC"
                    android:textSize="9sp"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginTop="2dp" />

                <ImageView
                    android:id="@+id/ivCheckCDQ"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_check"
                    android:tint="@color/primary"
                    android:layout_marginTop="2dp"
                    android:visibility="gone" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- HQ 选项 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHQ"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="@color/surface_light"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HQ"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="320K"
                    android:textSize="9sp"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginTop="2dp" />

                <ImageView
                    android:id="@+id/ivCheckHQ"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_check"
                    android:tint="@color/primary"
                    android:layout_marginTop="2dp"
                    android:visibility="gone" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- LQ 选项 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLQ"
            android:layout_width="64dp"
            android:layout_height="64dp"
            app:cardBackgroundColor="@color/surface_light"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LQ"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="128K"
                    android:textSize="9sp"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginTop="2dp" />

                <ImageView
                    android:id="@+id/ivCheckLQ"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_check"
                    android:tint="@color/primary"
                    android:layout_marginTop="2dp"
                    android:visibility="gone" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</LinearLayout>
