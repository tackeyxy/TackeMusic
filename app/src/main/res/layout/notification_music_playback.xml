<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notification_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- 主要内容区域 - 采用现代化卡片设计 -->
    <LinearLayout
        android:id="@+id/notification_content_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:background="@android:color/white"
        android:clickable="true"
        android:focusable="true">

        <!-- 专辑封面 - 圆角设计 -->
        <ImageView
            android:id="@+id/notification_album_art"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_album_default"
            android:background="@drawable/bg_notification_album_rounded" />

        <!-- 歌曲信息区域 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="10dp">

            <!-- 歌曲名称 -->
            <TextView
                android:id="@+id/notification_song_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="未知歌曲"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FF1A1A1A"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- 艺术家 -->
            <TextView
                android:id="@+id/notification_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="未知艺术家"
                android:textSize="13sp"
                android:textColor="#FF6B7280"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- 播放时间显示 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/notification_current_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textSize="11sp"
                    android:textColor="#FF9CA3AF"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" / "
                    android:textSize="11sp"
                    android:textColor="#FF9CA3AF" />

                <TextView
                    android:id="@+id/notification_total_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textSize="11sp"
                    android:textColor="#FF9CA3AF"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>

        <!-- 关闭按钮 -->
        <ImageView
            android:id="@+id/notification_close"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="8dp"
            android:src="@drawable/ic_close"
            android:contentDescription="关闭"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- 进度条 - 现代化细条设计 -->
    <ProgressBar
        android:id="@+id/notification_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        android:progressDrawable="@drawable/notification_progress_drawable"
        android:max="100"
        android:progress="0" />

    <!-- 控制按钮区域 - 现代化布局 -->
    <LinearLayout
        android:id="@+id/notification_controls_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="12dp"
        android:paddingTop="4dp">

        <!-- 上一首按钮 -->
        <ImageView
            android:id="@+id/notification_previous"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:src="@drawable/ic_skip_previous"
            android:contentDescription="上一首"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true" />

        <!-- 播放/暂停按钮 - 突出显示 -->
        <ImageView
            android:id="@+id/notification_play_pause"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:padding="10dp"
            android:src="@drawable/ic_play"
            android:contentDescription="播放/暂停"
            android:background="@drawable/bg_notification_play_button"
            android:clickable="true"
            android:focusable="true" />

        <!-- 下一首按钮 -->
        <ImageView
            android:id="@+id/notification_next"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:src="@drawable/ic_skip_next"
            android:contentDescription="下一首"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</LinearLayout>
