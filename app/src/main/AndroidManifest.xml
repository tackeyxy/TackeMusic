<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Android 13+ 使用新的媒体权限 -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <!-- 对于 Android 10+ 的存储访问 -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <!-- Android 16: 前台服务权限要求更严格 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <!-- Android 16: 添加前台服务数据同步权限（如需要） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- 悬浮窗权限 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- APK下载和安装权限 -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.DOWNLOAD_WITHOUT_NOTIFICATION" />
    <!-- 读取系统日志权限（Android 4.1+ 需要此权限来捕获日志） -->
    <uses-permission android:name="android.permission.READ_LOGS"
        tools:ignore="ProtectedPermissions" />

    <application
        android:name=".MusicApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TackeMusic"
        android:usesCleartextTraffic="true"
        android:enableOnBackInvokedCallback="true">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="screenSize|smallestScreenSize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.PlayerActivity"
            android:exported="false"
            android:theme="@style/Theme.TackeMusic.Player"
            android:launchMode="singleTop"
            android:configChanges="screenSize|smallestScreenSize" />

        <activity
            android:name=".ui.ProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.TackeMusic"
            android:launchMode="singleTop"
            android:configChanges="screenSize|smallestScreenSize" />

        <activity
            android:name=".ui.LyricsActivity"
            android:exported="false"
            android:theme="@style/Theme.TackeMusic"
            android:configChanges="screenSize|smallestScreenSize" />

        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false"
            android:configChanges="screenSize|smallestScreenSize" />

        <activity
            android:name=".ui.BackupRestoreActivity"
            android:exported="false"
            android:label="备份与恢复"
            android:configChanges="screenSize|smallestScreenSize" />

        <activity
            android:name=".ui.LyricSettingsActivity"
            android:exported="false"
            android:label="歌词设置"
            android:configChanges="screenSize|smallestScreenSize" />

        <activity
            android:name=".ui.PlayerCoverSettingsActivity"
            android:exported="false"
            android:label="播放页封面样式"
            android:configChanges="screenSize|smallestScreenSize" />

        <activity
            android:name=".ui.DownloadActivity"
            android:exported="false"
            android:configChanges="screenSize|smallestScreenSize" />

        <activity
            android:name=".ui.PlaylistActivity"
            android:exported="false"
            android:configChanges="screenSize|smallestScreenSize" />

        <activity
            android:name=".ui.PlaylistDetailActivity"
            android:exported="false"
            android:configChanges="screenSize|smallestScreenSize" />

        <activity
            android:name=".ui.RecentPlayActivity"
            android:exported="false"
            android:configChanges="screenSize|smallestScreenSize" />

        <activity
            android:name=".ui.ChartDetailActivity"
            android:exported="false"
            android:configChanges="screenSize|smallestScreenSize" />

        <activity
            android:name=".ui.NeteasePlaylistDetailActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|smallestScreenSize|keyboardHidden" />

        <activity
            android:name=".ui.FavoriteSongsActivity"
            android:exported="false"
            android:configChanges="screenSize|smallestScreenSize" />

        <activity
            android:name=".ui.LocalMusicActivity"
            android:exported="false"
            android:theme="@style/Theme.TackeMusic"
            android:configChanges="screenSize|smallestScreenSize" />

        <activity
            android:name=".ui.LogViewerActivity"
            android:exported="false"
            android:label="日志管理"
            android:configChanges="screenSize|smallestScreenSize" />

        <activity
            android:name=".ui.UpdateCheckActivity"
            android:exported="false"
            android:label="检测更新"
            android:configChanges="screenSize|smallestScreenSize" />

        <activity
            android:name=".ui.NewVersionActivity"
            android:exported="false"
            android:label="新版本"
            android:theme="@style/Theme.TackeMusic"
            android:configChanges="screenSize|smallestScreenSize" />

        <!-- Android 16: 前台服务需要明确指定 foregroundServiceType -->
        <service
            android:name=".service.MusicPlaybackService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback"
            android:permission="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

        <!-- 悬浮歌词服务 -->
        <service
            android:name=".service.FloatingLyricsService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- FileProvider for APK installation -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
